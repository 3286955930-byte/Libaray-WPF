<UserControl x:Class="LibrarySystem.Views.BorrowManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:LibrarySystem.ViewModels"
             xmlns:converters="clr-namespace:LibrarySystem.Converters">
    
    <UserControl.DataContext>
        <vm:BorrowManagementViewModel/>
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#ECF0F1" Padding="15,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📚 借书" 
                            Command="{Binding BorrowCommand}"
                            Background="#27AE60" 
                            Foreground="White"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
                
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" 
                             Padding="8"
                             VerticalContentAlignment="Center"
                             Margin="0,0,10,0"/>
                    <Button Content="🔍 搜索" 
                            Command="{Binding SearchCommand}"
                            Background="#3498DB" 
                            Foreground="White"
                            Padding="15,8"
                            BorderThickness="0"
                            Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding BorrowRecords}"
                  SelectedItem="{Binding SelectedRecord}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9"
                  HeadersVisibility="Column"
                  BorderThickness="0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="图书名称" Binding="{Binding BookTitle}" Width="*"/>
                <DataGridTextColumn Header="读者姓名" Binding="{Binding ReaderName}" Width="100"/>
                <DataGridTextColumn Header="借阅日期" Binding="{Binding BorrowDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="到期日期" Binding="{Binding DueDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="归还日期" Binding="{Binding ReturnDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridCheckBoxColumn Header="已归还" Binding="{Binding IsReturned}" Width="60"/>
                <DataGridCheckBoxColumn Header="逾期" Binding="{Binding IsOverdue}" Width="50"/>
                <DataGridTemplateColumn Header="操作" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="归还" 
                                    Command="{Binding DataContext.ReturnCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                    Background="#E67E22"
                                    Foreground="White"
                                    Padding="10,5"
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Visibility="{Binding IsReturned, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
        
        <Grid Visibility="{Binding IsBorrowDialogOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Border Background="Black" Opacity="0.5"/>
            <Border Background="White" 
                    CornerRadius="8" 
                    Padding="25"
                    Width="450"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="借书" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,0,0,20"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="选择图书：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" 
                                  ItemsSource="{Binding AvailableBooks}"
                                  SelectedItem="{Binding SelectedBook}"
                                  DisplayMemberPath="Title"
                                  Margin="0,0,0,10" Padding="5"/>
                        
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="选择读者：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" 
                                  ItemsSource="{Binding AvailableReaders}"
                                  SelectedItem="{Binding SelectedReader}"
                                  DisplayMemberPath="Name"
                                  Margin="0,0,0,10" Padding="5"/>
                        
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="借阅天数：" VerticalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding BorrowDays, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10" Padding="5"/>
                    </Grid>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                        <Button Content="确认借书" 
                                Command="{Binding SaveBorrowCommand}"
                                Background="#27AE60" 
                                Foreground="White"
                                Padding="20,8"
                                Margin="0,0,10,0"
                                BorderThickness="0"
                                Cursor="Hand"/>
                        <Button Content="取消" 
                                Command="{Binding CancelBorrowCommand}"
                                Background="#95A5A6" 
                                Foreground="White"
                                Padding="20,8"
                                BorderThickness="0"
                                Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
